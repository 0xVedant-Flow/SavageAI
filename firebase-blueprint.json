{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile tracking roast usage, rewards, and settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string" },
        "used_messages": { "type": "integer" },
        "daily_limit": { "type": "integer" },
        "last_reset_date": { "type": "string", "format": "date-time" },
        "reward_balance": { "type": "integer" },
        "is_first_time": { "type": "boolean" },
        "language": { "type": "string", "enum": ["bn", "en"] },
        "safeMode": { "type": "boolean" },
        "defaultMode": { "type": "string", "enum": ["funny", "savage", "dark", "friendly"] },
        "notificationsEnabled": { "type": "boolean" }
      },
      "required": ["uid", "used_messages", "daily_limit", "last_reset_date", "reward_balance", "is_first_time"]
    },
    "Roast": {
      "title": "Roast",
      "description": "A generated roast result.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "input": { "type": "string" },
        "output": { "type": "string" },
        "mode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "input", "output", "mode", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    },
    "/roasts/{roastId}": {
      "schema": "Roast",
      "description": "Generated roast history."
    }
  }
}
